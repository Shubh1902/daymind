generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  image     String?
  tasks     Task[]
  contexts  UserContext[]
  createdAt DateTime      @default(now())
}

model Task {
  id               String    @id @default(cuid())
  text             String
  deadline         DateTime?
  estimatedMinutes Int?
  actualMinutes    Int?
  priority         String    @default("medium")
  category         String?
  completed        Boolean   @default(false)
  completedAt      DateTime?
  deferCount       Int       @default(0)
  notes            String?
  capability       String?
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model UserContext {
  id        String   @id @default(cuid())
  key       String
  value     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, key])
}

model DailySession {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  briefing   String?
  plan       Json?
  userInputs Json?
  createdAt  DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// ─── Closet Module ────────────────────────────────

model ClothingItem {
  id          String   @id @default(cuid())
  userId      String
  imageData   String   // base64 data URI of the photo
  category    String   // "tops" | "bottoms" | "dresses" | "shoes" | "accessories"
  subcategory String?  // e.g. "t-shirt", "blouse", "jeans", "sneakers"
  color       String?  // primary color detected by AI
  colorHex    String?  // hex code for visual swatch, e.g. "#1e3a5f"
  pattern     String?  // e.g. "solid", "striped", "floral", "plaid"
  season      String?  // "spring", "summer", "fall", "winter", "all"
  vibes       String[] @default([]) // ["office", "nightlife", "party", "date", "casual", "gym", "brunch", "modest", "sexy"]
  name        String?  // optional user-given name
  favorite    Boolean  @default(false)
  wearCount   Int      @default(0)
  lastWornAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outfitItems   OutfitItem[]
  extraImages   ClothingItemImage[]
}

model ClothingItemImage {
  id             String       @id @default(cuid())
  clothingItemId String
  imageData      String       // base64 data URI
  label          String?      // "front", "back", "detail", "tag"
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  clothingItem   ClothingItem @relation(fields: [clothingItemId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String?  // "tops" | "bottoms" | "dresses" | "shoes" | "accessories"
  color       String?
  description String?
  reason      String?  // "gap analysis", "style upgrade", "manual"
  purchased   Boolean  @default(false)
  priority    String   @default("medium") // "low" | "medium" | "high"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Outfit {
  id              String               @id @default(cuid())
  userId          String
  name            String?
  occasion        String?              // "casual", "work", "date", "party"
  aiGenerated     Boolean              @default(false)
  saved           Boolean              @default(false)
  rating          Int?                 // 1-5 user rating
  feedback        String?              // AI feedback on the combination
  createdAt       DateTime             @default(now())
  items           OutfitItem[]
  calendarEntries OutfitCalendarEntry[]
}

model OutfitItem {
  id             String       @id @default(cuid())
  outfitId       String
  clothingItemId String
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  clothingItem   ClothingItem @relation(fields: [clothingItemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, clothingItemId])
}

model OutfitCalendarEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  outfitId  String?
  outfit    Outfit?  @relation(fields: [outfitId], references: [id], onDelete: SetNull)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model StyleProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  styleDna    Json     // { primary, secondary, breakdown }
  gapAnalysis Json?    // { categoryBalance, suggestions }
  analyzedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Household Task Tracker ───────────────────────

model HouseholdMember {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique // "shubhanshu" | "partner"
  color     String          // hex color for charts, e.g. "#f97316"
  tasks     HouseholdTask[]
  createdAt DateTime        @default(now())
}

model HouseholdTask {
  id              String          @id @default(cuid())
  choreType       String          // "cooking", "cleaning", "laundry", etc.
  description     String?         // optional note, e.g. "made pasta"
  durationMinutes Int             // actual or auto-estimated
  effortScore     Int             @default(2) // 1-5, auto-filled from choreType
  memberId        String
  member          HouseholdMember @relation(fields: [memberId], references: [id])
  completedAt     DateTime        @default(now())
  source          String          @default("form") // "form" | "voice"
  createdAt       DateTime        @default(now())

  @@index([memberId, completedAt])
  @@index([choreType, completedAt])
}

// ─── Football Team Maker ──────────────────────────

model FootballPlayer {
  id        String   @id @default(cuid())
  name      String
  position  String   // primary position: "GK", "CB", "CM", "ST", etc.
  positions String[] @default([]) // all positions player can play
  // FIFA-style attributes (1-99)
  pace      Int      @default(50)  // PAC — speed and acceleration
  shooting  Int      @default(50)  // SHO — finishing and shot power
  passing   Int      @default(50)  // PAS — short/long passing, vision
  dribbling Int      @default(50)  // DRI — ball control, agility
  defending Int      @default(50)  // DEF — tackling, interceptions
  physical  Int      @default(50)  // PHY — stamina, strength, aggression
  // Legacy fields (kept for backward compat, computed from new attrs)
  skill     Int      @default(50)  // overall rating (computed)
  workRate  String   @default("Med")
  notes     String?
  aliases          String[] @default([]) // alternate names: "Shubh", "SB" etc.
  active           Boolean  @default(true)
  waitlisted       Boolean  @default(false)
  waitlistPriority Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gameSelections FootballGamePlayer[]
  goals          FootballGoal[]   @relation("GoalScorer")
  assists        FootballGoal[]   @relation("GoalAssist")
}

model FootballGame {
  id           String   @id @default(cuid())
  name         String?
  instructions String?
  teamAPlayers Json     // snapshot: [{ playerId, name, position, skill, role }]
  teamBPlayers Json     // snapshot: [{ playerId, name, position, skill, role }]
  matchDate    DateTime? // when the match is/was played
  balanceScore Float?
  jerseyA      String?  // jersey color id: "black", "white", etc.
  jerseyB      String?
  scoreA       Int?     // final score team A
  scoreB       Int?     // final score team B
  completed    Boolean  @default(false) // true after recording result
  createdAt    DateTime @default(now())

  selections FootballGamePlayer[]
  goals      FootballGoal[]
}

model FootballGoal {
  id             String          @id @default(cuid())
  gameId         String
  playerId       String
  assistPlayerId String?
  team           String          // "A" | "B"
  minute         Int?
  game           FootballGame    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player         FootballPlayer  @relation("GoalScorer", fields: [playerId], references: [id], onDelete: Cascade)
  assistPlayer   FootballPlayer? @relation("GoalAssist", fields: [assistPlayerId], references: [id], onDelete: SetNull)
}

model FootballGamePlayer {
  id       String         @id @default(cuid())
  gameId   String
  playerId String
  team     String         // "A" | "B"
  role     String         // "outfield" | "gk" | "sub"
  game     FootballGame   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player   FootballPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
}
